---

extends: default

ignore: |
  .venv/
  venv/
  .ansible/
  build/
  changelogs/changelog.yaml
  collections/
  tests/output/
  changelogs/.plugin-cache.yaml

rules:
  line-length: disable
  truthy: disable
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
